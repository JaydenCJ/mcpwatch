{
  "name": "demo-notes",
  "version": "1.0.0",
  "tools": [
    {
      "name": "add_note",
      "description": "Create a note with a title and body",
      "inputSchema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" }
        },
        "required": ["title"]
      }
    },
    {
      "name": "echo",
      "description": "Echo a message back verbatim",
      "inputSchema": {
        "type": "object",
        "properties": { "text": { "type": "string" } },
        "required": ["text"]
      }
    }
  ],
  "resources": [
    {
      "uri": "notes://today",
      "name": "Today's notes",
      "mimeType": "text/markdown"
    }
  ],
  "resourceTemplates": [
    {
      "uriTemplate": "notes://{date}",
      "name": "Notes by date",
      "mimeType": "text/markdown"
    }
  ],
  "prompts": [
    {
      "name": "summarize",
      "description": "Summarize the notes of one day",
      "arguments": [
        { "name": "date", "required": true },
        { "name": "style" }
      ]
    }
  ]
}
